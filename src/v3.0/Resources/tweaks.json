    "Id": "MPO_Disable",
    "DisplayName": "Отключение Multi-Plane Overlay (MPO)",
    "Description": "Устраняет микрофризы, мерцания экрана на картах NVIDIA/AMD в играх.",
    "Category": "System",
    "CheckRegistryPath": "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows\\Dwm",
    "CheckValueName": "OverlayTestMode",
    "ExpectedValue": 5,
    "ApplyOperations": [
      {
        "KeyPath": "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows\\Dwm",
        "ValueName": "OverlayTestMode",
        "Value": 5,
        "ValueKind": 4
      }
    ],
    "RevertOperations": [
      {
        "KeyPath": "HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows\\Dwm",
        "ValueName": "OverlayTestMode",
        "Value": 0,
        "ValueKind": 4
      }
    ]
  },
